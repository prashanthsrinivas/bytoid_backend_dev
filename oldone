@app.before_request
def validate_cookie_session():
    if request.endpoint in EXEMPT_PATHS or request.endpoint is None:
        return
    session_id = request.cookies.get('session_id')
    if session_id:
        if not session_manager.is_session_valid(session_id):
            # Invalidate expired session
            session_manager.delete_session(session_id)
            response = make_response({'error': 'Session expired'}, 440)  # 440 is often used for login timeout
            response.delete_cookie('session_id')
            return response
        else:
            session_manager.update_session_timestamp(session_id)

@app.route("/sub_agent_ask", methods=["POST"])
def sub_agent_ask():
    try:
        # Initialize PineconeManager
        pinecone_manager = PineconeManager()

        data = request.get_json()

        if not data or "query" not in data:
            return jsonify({"error": "A 'query' is required in the JSON body."}), 400

        query = data.get("query")

        if query == ":login":
            auth_url = login()
            return jsonify({"answer": auth_url}), 200

        elif query == ":oauth":
            oauth2callback()
            return jsonify({"answer": "OAuth process completed."}), 200

        elif query == ":sync_drive":
            sync_drive()
            return jsonify({"answer": "Drive sync initiated."}), 200

        # Utilize the query_documents method from PineconeManager
        result = pinecone_manager.query_documents(query)

        return jsonify({
            "answer": result["answer"],
            "sources": result["sources"]
        }), 200

    except Exception as e:
        return jsonify({"error": str(e)}), 500



