def format_address(door, unit, street, zip_code):
    parts = [
        f"Door {door}" if door else None,
        f"Unit {unit}" if unit else None,
        street,
        f"ZIP {zip_code}" if zip_code else None
    ]
    return ', '.join([p for p in parts if p])


