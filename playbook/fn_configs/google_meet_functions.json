{
    "functions": [
        {
            "category": "Google Meet",
            "name": "google_meet.get_all_available_slots",
            "description": "Retrieve all available meeting time slots across multiple attendees using Google Calendar FreeBusy API.",
            "channels": "google_meet",
            "communication_mode": "calender",
            "status": "active",
            "args": {
                "attendees": "list of attendee email addresses",
                "preferred_date": "string (YYYY-MM-DD)",
                "start_time": "string (HH:MM, 24-hour)",
                "end_time": "string (HH:MM, 24-hour)",
                "duration_minutes": "integer (meeting duration in minutes) default intger 60",
                "days_to_check": "optional integer (default: 5, number of days to scan)",
                "timezone": "optional string (IANA timezone, default: None)"
            },
            "returns": {
                "slots": "list of dicts with { start, end, date }"
            }
        },
        {
            "category": "Google Meet",
            "name": "google_meet.create_meeting",
            "description": "Create a Google Calendar meeting event with a Meet link for given attendees (emails only). as it takes the first available slot based on details this is preferred",
            "channels": "google_meet",
            "communication_mode": "calender",
            "status": "active",
            "args": {
                "summary": "string (meeting title)",
                "start_time": "string (ISO format: YYYY-MM-DDTHH:MM:SS)",
                "end_time": "string (ISO format: YYYY-MM-DDTHH:MM:SS)",
                "attendees": "optional list of attendee emails",
                "description": "optional string (meeting details or notes)",
                "timezone": "optional string (IANA timezone, default: None)"
            },
            "returns": {
                "event_id": "string",
                "summary": "string",
                "meet_link": "string (Google Meet URL)",
                "start_time": "object (with dateTime and timeZone)",
                "end_time": "object (with dateTime and timeZone)",
                "attendees": "list of attendee objects",
                "return_str": "a message type return so that it can be used on chatbot or email body"
            }
        },
        {
            "category": "Google Meet",
            "name": "google_meet.get_attendees_or_contacts",
            "description": "Retrieve a cleaned, validated list of attendees or fallback contacts (emails only). Supports both testing and normal modes, validates replyable emails, and handles the 'all' keyword to include all contacts. (it is recommended for retrieving meeting or gmail based functions for contacts or emails)",
            "channels": "google_meet",
            "communication_mode": "calender",
            "status": "active",
            "args": {
                "attendees": "string or list — attendee email(s) or 'all' keyword"
            },
            "returns": {
                "attendees": "list of valid attendee email addresses"
            },
            "notes": [
                "In testing mode, uses TEST_EMAIL and TEST_EMAIL2 environment variables as fallback.",
                "Validates emails using can_reply_to_email().",
                "If 'all' is passed, returns all replyable contact emails.",
                "Falls back to empty list if no valid attendees found."
            ]
        },
        {
            "category": "Google Meet",
            "name": "google_meet.schedule_meeting_on_first_available",
            "description": "Find the first available slot across attendees (emails only) and schedule a Google Meet automatically by assigning current date and time if they dont mentioned, as per emails we take user emails or use all contacts or emails.",
            "channels": "google_meet",
            "communication_mode": "calender",
            "status": "active",
            "args": {
                "summary": "string (meeting title)",
                "attendees": "list of attendee emails",
                "preferred_date": "string (YYYY-MM-DD)",
                "start_time": "string (HH:MM, 24-hour)",
                "end_time": "string (HH:MM, 24-hour)",
                "duration_minutes": "integer (meeting duration in minutes) default intger 60",
                "description": "optional string (meeting description)",
                "timezone": "optional string (IANA timezone, default: None)"
            },
            "returns": {
                "success": "boolean",
                "meeting": "dict with { event_id, summary, meet_link, start_time, end_time, attendees } or error reason"
            }
        },
